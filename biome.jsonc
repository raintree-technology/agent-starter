{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "extends": ["./biome.base.jsonc"],
  "files": {
    "includes": [
      ".github/**/*.yml",
      "bench/**/*.mjs",
      "bin/**/*.js",
      "package-lock.json",
      "package.json",
      "src/**/*.js",
      "templates/**/*.js",
      "templates/**/*.json",
      "test/**/*.js"
    ]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "linter": {
    "rules": {
      "suspicious": {
        "noTemplateCurlyInString": "off"
      }
    }
  }
}
